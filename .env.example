# Sentence provider: ollama | hf
SENTISIGN_SENTENCE_PROVIDER=ollama
SENTISIGN_OLLAMA_MODEL=qwen3.5:0.8b
SENTISIGN_OLLAMA_HOST=http://127.0.0.1:11434

# Default TTS provider: chatterbox | elevenlabs
SENTISIGN_TTS_PROVIDER=chatterbox

# ElevenLabs settings (required only when SENTISIGN_TTS_PROVIDER=elevenlabs,
# or when selecting ElevenLabs from the web UI / desktop prompt).
ELEVENLABS_API_KEY=your_api_key_here
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_MODEL_ID=eleven_flash_v2_5
